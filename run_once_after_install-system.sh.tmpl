#!/bin/bash
# This script runs once after chezmoi applies files
echo "🚀 Starting Ansible System Setup..."

# Install Ansible if missing
if ! command -v ansible &> /dev/null; then
    sudo apt update && sudo apt install -y ansible
fi

# Run the playbook
sudo ansible-playbook {{ .chezmoi.sourceDir }}/ansible/playbook.yml -i {{ .chezmoi.sourceDir }}/ansible/inventory --ask-become-pass

